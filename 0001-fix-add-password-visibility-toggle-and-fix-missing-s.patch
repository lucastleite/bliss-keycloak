From a2f7d4c9031c13a5767fec6399d2fa811a90de28 Mon Sep 17 00:00:00 2001
From: Lucas Leite <lucas.leite@hotmart.com>
Date: Mon, 11 May 2026 14:29:20 -0300
Subject: [PATCH] fix: add password visibility toggle and fix missing submit
 button on update-profile

---
 themes/bliss/login/login-update-password.ftl | 43 +++++++++++++++++++-
 themes/bliss/login/login-update-profile.ftl  |  2 +-
 themes/bliss/login/login.ftl                 | 30 +++++++++++++-
 themes/bliss/login/resources/css/bliss.css   | 29 +++++++++++++
 4 files changed, 100 insertions(+), 4 deletions(-)

diff --git a/themes/bliss/login/login-update-password.ftl b/themes/bliss/login/login-update-password.ftl
index 44d46a4..aef7f49 100644
--- a/themes/bliss/login/login-update-password.ftl
+++ b/themes/bliss/login/login-update-password.ftl
@@ -2,16 +2,55 @@
 <@layout.registrationLayout displayMessage=!messagesPerField.existsError('password','password-confirm') displayInfo=false; section>
     <#if section = "form">
         <form id="kc-passwd-update-form" action="${url.loginAction}" method="post">
-            <div class="bliss-input-group">
+            <div class="bliss-input-group bliss-password-group">
                 <input id="password-new" name="password-new" type="password" placeholder=" " autocomplete="new-password" autofocus>
                 <label for="password-new">${msg("passwordNew")}</label>
+                <button type="button" class="bliss-toggle-password" aria-label="Toggle password visibility" onclick="togglePassword('password-new', this)">
+                    <svg class="eye-open" xmlns="http://www.w3.org/2000/svg" width="20" height="20" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round">
+                        <path d="M1 12s4-8 11-8 11 8 11 8-4 8-11 8-11-8-11-8z"></path>
+                        <circle cx="12" cy="12" r="3"></circle>
+                    </svg>
+                    <svg class="eye-closed" xmlns="http://www.w3.org/2000/svg" width="20" height="20" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round" style="display:none">
+                        <path d="M17.94 17.94A10.07 10.07 0 0 1 12 20c-7 0-11-8-11-8a18.45 18.45 0 0 1 5.06-5.94"></path>
+                        <path d="M9.9 4.24A9.12 9.12 0 0 1 12 4c7 0 11 8 11 8a18.5 18.5 0 0 1-2.16 3.19"></path>
+                        <line x1="1" y1="1" x2="23" y2="23"></line>
+                    </svg>
+                </button>
             </div>
 
-            <div class="bliss-input-group">
+            <div class="bliss-input-group bliss-password-group">
                 <input id="password-confirm" name="password-confirm" type="password" placeholder=" " autocomplete="new-password">
                 <label for="password-confirm">${msg("passwordConfirm")}</label>
+                <button type="button" class="bliss-toggle-password" aria-label="Toggle password visibility" onclick="togglePassword('password-confirm', this)">
+                    <svg class="eye-open" xmlns="http://www.w3.org/2000/svg" width="20" height="20" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round">
+                        <path d="M1 12s4-8 11-8 11 8 11 8-4 8-11 8-11-8-11-8z"></path>
+                        <circle cx="12" cy="12" r="3"></circle>
+                    </svg>
+                    <svg class="eye-closed" xmlns="http://www.w3.org/2000/svg" width="20" height="20" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round" style="display:none">
+                        <path d="M17.94 17.94A10.07 10.07 0 0 1 12 20c-7 0-11-8-11-8a18.45 18.45 0 0 1 5.06-5.94"></path>
+                        <path d="M9.9 4.24A9.12 9.12 0 0 1 12 4c7 0 11 8 11 8a18.5 18.5 0 0 1-2.16 3.19"></path>
+                        <line x1="1" y1="1" x2="23" y2="23"></line>
+                    </svg>
+                </button>
             </div>
 
+            <script>
+                function togglePassword(inputId, btn) {
+                    var input = document.getElementById(inputId);
+                    var eyeOpen = btn.querySelector('.eye-open');
+                    var eyeClosed = btn.querySelector('.eye-closed');
+                    if (input.type === 'password') {
+                        input.type = 'text';
+                        eyeOpen.style.display = 'none';
+                        eyeClosed.style.display = 'block';
+                    } else {
+                        input.type = 'password';
+                        eyeOpen.style.display = 'block';
+                        eyeClosed.style.display = 'none';
+                    }
+                }
+            </script>
+
             <input class="bliss-btn" type="submit" value="${msg("doSubmit")}">
         </form>
     </#if>
diff --git a/themes/bliss/login/login-update-profile.ftl b/themes/bliss/login/login-update-profile.ftl
index 4c076b4..711db65 100644
--- a/themes/bliss/login/login-update-profile.ftl
+++ b/themes/bliss/login/login-update-profile.ftl
@@ -14,7 +14,7 @@
                 <label for="lastName">${msg("lastName")}</label>
             </div>
 
-            <input type="hidden" name="email" value="${(user.email!'')}"
+            <input type="hidden" name="email" value="${(user.email!'')}">
 
             <input class="bliss-btn" type="submit" value="${msg("doSubmit")}">
         </form>
diff --git a/themes/bliss/login/login.ftl b/themes/bliss/login/login.ftl
index ab973b2..b4579df 100644
--- a/themes/bliss/login/login.ftl
+++ b/themes/bliss/login/login.ftl
@@ -9,10 +9,38 @@
                 <label for="username">${msg("email")}</label>
             </div>
 
-            <div class="bliss-input-group">
+            <div class="bliss-input-group bliss-password-group">
                 <input id="password" name="password" type="password" autocomplete="current-password" placeholder=" ">
                 <label for="password">${msg("password")}</label>
+                <button type="button" class="bliss-toggle-password" aria-label="Toggle password visibility" onclick="togglePassword()">
+                    <svg class="eye-open" xmlns="http://www.w3.org/2000/svg" width="20" height="20" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round">
+                        <path d="M1 12s4-8 11-8 11 8 11 8-4 8-11 8-11-8-11-8z"></path>
+                        <circle cx="12" cy="12" r="3"></circle>
+                    </svg>
+                    <svg class="eye-closed" xmlns="http://www.w3.org/2000/svg" width="20" height="20" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round" style="display:none">
+                        <path d="M17.94 17.94A10.07 10.07 0 0 1 12 20c-7 0-11-8-11-8a18.45 18.45 0 0 1 5.06-5.94"></path>
+                        <path d="M9.9 4.24A9.12 9.12 0 0 1 12 4c7 0 11 8 11 8a18.5 18.5 0 0 1-2.16 3.19"></path>
+                        <line x1="1" y1="1" x2="23" y2="23"></line>
+                    </svg>
+                </button>
             </div>
+            <script>
+                function togglePassword() {
+                    var input = document.getElementById('password');
+                    var btn = document.querySelector('.bliss-toggle-password');
+                    var eyeOpen = btn.querySelector('.eye-open');
+                    var eyeClosed = btn.querySelector('.eye-closed');
+                    if (input.type === 'password') {
+                        input.type = 'text';
+                        eyeOpen.style.display = 'none';
+                        eyeClosed.style.display = 'block';
+                    } else {
+                        input.type = 'password';
+                        eyeOpen.style.display = 'block';
+                        eyeClosed.style.display = 'none';
+                    }
+                }
+            </script>
 
             <#if realm.rememberMe && !usernameEditDisabled??>
                 <div class="bliss-remember">
diff --git a/themes/bliss/login/resources/css/bliss.css b/themes/bliss/login/resources/css/bliss.css
index f620880..a964ebc 100644
--- a/themes/bliss/login/resources/css/bliss.css
+++ b/themes/bliss/login/resources/css/bliss.css
@@ -221,6 +221,35 @@ html, body {
     transform: scale(1.2) !important;
 }
 
+/* Password toggle (eye icon) */
+.bliss-password-group {
+    position: relative !important;
+}
+
+.bliss-password-group input {
+    padding-right: 3rem !important;
+}
+
+.bliss-toggle-password {
+    position: absolute !important;
+    right: 0.75rem !important;
+    top: 50% !important;
+    transform: translateY(-50%) !important;
+    background: none !important;
+    border: none !important;
+    cursor: pointer !important;
+    color: var(--bliss-text-muted) !important;
+    padding: 0.25rem !important;
+    display: flex !important;
+    align-items: center !important;
+    justify-content: center !important;
+    transition: color 0.2s ease !important;
+}
+
+.bliss-toggle-password:hover {
+    color: var(--bliss-primary) !important;
+}
+
 /* Remember me checkbox */
 .bliss-remember {
     display: flex !important;
-- 
2.50.1 (Apple Git-155)

